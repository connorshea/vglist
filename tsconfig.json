{
  "compilerOptions": {
    "lib": ["esnext", "dom", "dom.iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "target": "esnext",
    "skipLibCheck": false,
    "verbatimModuleSyntax": true,
    "strict": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "app/javascript/**/*.ts",
    "app/javascript/**/*.d.ts",
    "app/javascript/src/**/*.vue",
    "vite.config.ts"
  ],
  "exclude": ["**/*.spec.ts", "node_modules", "vendor", "public"],
  "compileOnSave": false,
  "vueCompilerOptions": {
    "target": 3.5,
    "extensions": [".vue"],
    "strictTemplates": true
  }
}
