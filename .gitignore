# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

###############################################################
###############################################################
####### NOTE: If you're updating this file you may   ##########
#######       also want to update the .dockerignore. ##########
###############################################################
###############################################################

# Ignore bundler config.
/.bundle

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

/shared/*
!/shared/.keep

# Ignore uploaded files in development
/storage/*
!/storage/.keep

/node_modules
/pnpm-debug.log*
.pnpm-store/

/public/assets
/public/index.html
.byebug_history

# Ignore master key for decrypting credentials and more.
/config/master.key
/public/packs
/public/packs-test
/node_modules
coverage/

.DS_Store
spec/examples.txt
prod.env

sbin/
.vscode/settings.json

# Ignore GraphQL Schema generated by rake graphql:schema:json
/schema.json
/schema.graphql

/vendor/*
.env

# Worktree-local environment overrides (written by bin/setup-worktree)
.env.local
.env.*.local
/frontend/.env.local
/frontend/.env.*.local

/app/assets/builds/*
!/app/assets/builds/.keep

.playwright-mcp/

# Ignore credential keys, but keep test key for development and testing.
/config/credentials/*.key
!/config/credentials/test.key

# Claude
.claude/worktrees/
