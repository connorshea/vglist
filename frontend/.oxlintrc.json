{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "import", "vue", "vitest", "unicorn"],
  "categories": {
    "correctness": "error"
  },
  "options": {
    "typeAware": true
  },
  "env": {
    "builtin": true,
    "es2024": true
  },
  "ignorePatterns": [],
  "rules": {
    "eqeqeq": ["error", "smart"],
    "unicorn/no-abusive-eslint-disable": "error",
    "typescript/no-unnecessary-type-assertion": "error",
    "typescript/no-unnecessary-type-constraint": "error",
    "typescript/consistent-type-exports": "error",
    "unicorn/no-lonely-if": "error"
  },
  "overrides": [
    {
      "files": ["src/**/*.{ts,vue}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "graphql-tag",
                "message": "Import graphql-tag only in src/graphql/ files. Components and pages should import queries/mutations from src/graphql/ modules."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/graphql/**/*.ts"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
