{
  "name": "vglist-frontend",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "oxlint",
    "lint:schema": "graphql-schema-linter ../schema.graphql",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen": "graphql-codegen && oxfmt && oxfmt"
  },
  "dependencies": {
    "@lucide/vue": "^1.23.0",
    "@sentry/vue": "^10.63.0",
    "bulma": "^1.0.4",
    "graphql": "^17.0.2",
    "graphql-request": "^7.4.0",
    "graphql-tag": "^2.12.7",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "sass-embedded": "^1.100.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.2.0",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-operations": "^6.1.0",
    "@types/lodash-es": "^4.17.12",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "graphql-schema-linter": "^3.0.1",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  },
  "packageManager": "pnpm@11.10.0"
}
