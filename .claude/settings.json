{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "matcher": "Stop",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$CONDUCTOR_WORKSPACE_NAME\" ] && exit 0; cd \"$CLAUDE_PROJECT_DIR/frontend\" && pnpm run typecheck || exit 2",
            "timeout": 25,
            "statusMessage": "Running pnpm typecheck"
          },
          {
            "type": "command",
            "command": "[ -n \"$CONDUCTOR_WORKSPACE_NAME\" ] && exit 0; cd \"$CLAUDE_PROJECT_DIR/frontend\" && pnpm run lint || exit 2",
            "timeout": 10,
            "statusMessage": "Running pnpm lint"
          },
          {
            "type": "command",
            "command": "[ -n \"$CONDUCTOR_WORKSPACE_NAME\" ] && exit 0; cd \"$CLAUDE_PROJECT_DIR/frontend\" && pnpm run fmt:check || exit 2",
            "timeout": 15,
            "statusMessage": "Running pnpm fmt:check"
          },
          {
            "type": "command",
            "command": "[ -n \"$CONDUCTOR_WORKSPACE_NAME\" ] && exit 0; cd \"$CLAUDE_PROJECT_DIR\" && bundle exec rubocop --cache false || exit 2",
            "timeout": 30,
            "statusMessage": "Running rubocop"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "managing-dependencies@managing-dependencies": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "frontend/node_modules/ts-log/.vscode/settings.json",
        "frontend/node_modules/ts-log/.vscode/launch.json"
      ]
    },
    "enableWeakerNetworkIsolation": true
  }
}
