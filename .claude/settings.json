{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "matcher": "Stop",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR/frontend\" && yarn run fmt && cd .."
          },
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR/frontend\" && yarn run typecheck && cd .."
          }
        ]
      }
    ]
  }
}
